<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Scripts/USS/CollectionScreenUSS.uss?fileID=7433441132597879392&amp;guid=ce0b88583c4266649b8cd3343dfdc85a&amp;type=3#CollectionScreenUSS" />
    <ui:VisualElement name="VisualElement" class="top-bar" style="width: auto; flex-grow: 0; padding-bottom: 10px; padding-top: 10px; padding-left: 60px; padding-right: 20px;">
        <ui:VisualElement class="nav-buttons" style="min-width: auto; max-width: none; max-height: none; min-height: auto; height: 86px;">
            <ParallelogramButton text="EXIT" name="exitButton" class="nav-button" style="font-size: 25px;" />
        </ui:VisualElement>
        <ui:Label text="BESTIARY" style="position: absolute; top: 28px; left: 906px; width: 650px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(106, 172, 110); border-right-color: rgb(106, 172, 110); border-top-color: rgb(106, 172, 110); border-bottom-color: rgb(106, 172, 110); height: 68px; color: rgb(143, 224, 66); font-size: 40px; -unity-text-align: upper-center;" />
    </ui:VisualElement>
    <ui:VisualElement class="main-content" style="flex-direction: row; flex-grow: 1; padding-bottom: 5px; padding-top: 0; display: flex;">
        <ui:ScrollView name="cardScrollView" vertical-scroller-visibility="Hidden" horizontal-scroller-visibility="Hidden" touch-scroll-type="Clamped" focusable="false" enabled="true" nested-interaction-kind="Default" mode="Vertical" style="flex-grow: 1; padding: 10px; flex-wrap: nowrap; align-content: auto; -unity-slice-type: sliced; max-height: none; width: auto; flex-basis: auto; flex-shrink: 1; flex-direction: row; height: auto; align-items: flex-start; display: flex; justify-content: flex-start; background-color: rgba(72, 183, 91, 0); padding-top: 5px;" />
    </ui:VisualElement>
    <ui:VisualElement class="filters-container" style="flex-direction: row-reverse; justify-content: flex-start; align-items: flex-start; width: 100%; height: 10%; padding: 5px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
        <ui:VisualElement class="filter-group" style="flex-direction: row; align-items: center; width: 50%; justify-content: flex-start; padding-right: 80px; align-self: auto; height: 100%; padding-bottom: 15px; padding-top: 5px;">
            <ui:Label text="ELEMENTS" class="filter-title" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; font-size: 20px;" />
            <ui:VisualElement name="elementsIconsContainer" class="element-icons-container" style="flex-direction: row; align-items: center; justify-content: space-evenly; width: auto; height: 100%; flex-grow: 1;">
                <ui:Button name="grass" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/grass&apos;);" />
