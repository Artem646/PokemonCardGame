                <ui:Button name="water" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/water&apos;);" />
                <ui:Button name="bug" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/bug&apos;);" />
                <ui:Button name="psychic" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/psychic&apos;);" />
                <ui:Button name="fighting" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/fighting&apos;);" />
                <ui:Button name="flying" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/flying&apos;);" />
                <ui:Button name="electric" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/electric&apos;);" />
                <ui:Button name="ground" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/ground&apos;);" />
                <ui:Button name="normal" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/normal&apos;);" />
                <ui:Button name="poison" class="element-icon" style="background-image: resource(&apos;Sprites/Elements/poison&apos;);" />
